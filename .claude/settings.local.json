{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git revert*)",
      "Bash(git tag*)",
      "Bash(git stash drop*)",
      "Bash(git branch -d*)",
      "Bash(git branch -D*)",
      "Bash(git checkout -B*)",
      "Bash(git add*)"
    ]
  }
}